*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, Helvetica, sans-serif;
    background:#f4f4f4;
    color:#333;
    line-height:1.6;
}

.container{
    width:90%;
    max-width:1200px;
    margin:auto;
}

header{
    background:#222;
    color:white;
    padding:20px 0;
}

header .container{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

header h1{
    font-size:28px;
}

nav ul{
    display:flex;
    list-style:none;
}

nav ul li{
    margin-left:20px;
}

nav ul li a{
    color:white;
    text-decoration:none;
    transition:.3s;
}

nav ul li a:hover{
    color:#00bfff;
}

.hero{
    background:linear-gradient(135deg,#007bff,#00d4ff);
    color:white;
    text-align:center;
    padding:80px 20px;
}

.hero h2{
    font-size:42px;
    margin-bottom:10px;
}

.hero p{
    font-size:18px;
}

main{
    display:grid;
    grid-template-columns:3fr 1fr;
    gap:30px;
    margin:40px auto;
}

.post{
    background:white;
    border-radius:10px;
    overflow:hidden;
    margin-bottom:30px;
    box-shadow:0 2px 10px rgba(0,0,0,.1);
}

.post img{
    width:100%;
    display:block;
}

.post h2{
    padding:20px;
}

.post .date{
    color:#777;
    padding:0 20px;
    font-size:14px;
}

.post p{
    padding:20px;
}

.btn{
    display:inline-block;
    margin:0 20px 20px;
    padding:10px 20px;
    background:#007bff;
    color:white;
    text-decoration:none;
    border-radius:5px;
}

.btn:hover{
    background:#0056b3;
}

.sidebar .widget{
    background:white;
    padding:20px;
    margin-bottom:20px;
    border-radius:10px;
    box-shadow:0 2px 10px rgba(0,0,0,.1);
}

.widget h3{
    margin-bottom:15px;
}

.widget ul{
    list-style:none;
}

.widget ul li{
    margin-bottom:10px;
}

.widget ul li a{
    text-decoration:none;
    color:#007bff;
}

.widget input{
    width:100%;
    padding:10px;
    margin-bottom:10px;
}

.widget button{
    width:100%;
    padding:10px;
    border:none;
    background:#007bff;
    color:white;
    cursor:pointer;
    border-radius:5px;
}

.widget button:hover{
    background:#0056b3;
}

footer{
    background:#222;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:40px;
}

@media(max-width:768px){

    header .container{
        flex-direction:column;
    }

    nav ul{
        flex-direction:column;
        text-align:center;
        margin-top:15px;
    }

    nav ul li{
        margin:10px 0;
    }

    main{
        grid-template-columns:1fr;
    }

    .hero h2{
        font-size:30px;
    }
}
