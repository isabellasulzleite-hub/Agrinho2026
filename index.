:root{
    --bg:#0f172a;
    --card:#1e293b;
    --text:#f8fafc;
    --accent:#3b82f6;
}

.light{
    --bg:#f5f5f5;
    --card:#ffffff;
    --text:#111827;
    --accent:#2563eb;
}

html{
    scroll-behavior:smooth;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{

    background:linear-gradient(
        -45deg,
        #0f172a,
        #1e293b,
        #1e3a8a,
        #0f172a
    );

    background-size:400% 400%;

    animation:gradient 15s ease infinite;

    color:var(--text);

    transition:.4s;
}

@keyframes gradient{
    0%{
        background-position:0% 50%;
    }
    50%{
        background-position:100% 50%;
    }
    100%{
        background-position:0% 50%;
    }
}

header{

    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:25px 10%;

    position:sticky;
    top:0;

    background:rgba(15,23,42,.7);

    backdrop-filter:blur(20px);

    border-bottom:1px solid rgba(255,255,255,.08);

    z-index:1000;
}

.logo{
    font-size:1.8rem;
    font-weight:700;
    color:var(--accent);
}

nav a{
    text-decoration:none;
    color:var(--text);
    margin:0 15px;
    transition:.3s;
}

nav a:hover{
    color:var(--accent);
}

#theme-btn{
    border:none;
    background:none;
    color:white;
    font-size:1.5rem;
    cursor:pointer;
}

.hero{
    min-height:90vh;

    display:flex;
    justify-content:center;
    align-items:center;

    text-align:center;

    padding:20px;
}

.hero-content{
    max-width:900px;
}

.tag{
    background:rgba(59,130,246,.15);
    color:#60a5fa;
    padding:10px 20px;
    border-radius:50px;
}

.hero h1{

    font-size:5rem;
    font-weight:800;

    background:
    linear-gradient(
        90deg,
        #ffffff,
        #60a5fa
    );

    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;

    margin:25px 0;
}

.hero p{
    font-size:1.2rem;
    opacity:.8;
}

.hero-btn{

    display:inline-block;

    margin-top:30px;

    padding:16px 40px;

    border-radius:50px;

    text-decoration:none;

    color:white;

    background:
    linear-gradient(
        45deg,
        #3b82f6,
        #60a5fa
    );

    box-shadow:
    0 0 20px rgba(59,130,246,.4);

    transition:.4s;
}

.hero-btn:hover{
    transform:translateY(-5px);

    box-shadow:
    0 0 40px rgba(59,130,246,.7);
}

.posts{

    display:grid;

    grid-template-columns:
    repeat(auto-fit,minmax(350px,1fr));

    gap:30px;

    padding:80px 10%;
}

.card{

    background:rgba(255,255,255,.05);

    backdrop-filter:blur(20px);

    border:1px solid rgba(255,255,255,.08);

    border-radius:25px;

    overflow:hidden;

    box-shadow:
    0 8px 32px rgba(0,0,0,.3);

    transition:.4s;

    animation:fadeUp .8s ease forwards;
}

.card:hover{

    transform:
    translateY(-12px)
    scale(1.02);

    box-shadow:
    0 20px 40px rgba(59,130,246,.25);
}

.card img{

    width:100%;
    height:250px;

    object-fit:cover;

    transition:.6s;
}

.card:hover img{
    transform:scale(1.08);
}

.card-content{
    padding:25px;
}

.card-content span{
    color:#60a5fa;
}

.card-content h2{
    margin:15px 0;
}

.card-content p{
    opacity:.8;
}

.card-content a{
    display:inline-block;
    margin-top:20px;
    color:#60a5fa;
    text-decoration:none;
}

.newsletter{
    text-align:center;
    padding:100px 20px;
}

.newsletter h2{
    margin-bottom:15px;
}

.newsletter input{

    width:320px;
    max-width:90%;

    padding:15px;

    border:none;

    border-radius:50px;
}

.newsletter button{

    padding:15px 30px;

    border:none;

    border-radius:50px;

    background:#3b82f6;

    color:white;

    cursor:pointer;

    margin-left:10px;
}

footer{

    text-align:center;

    padding:40px;

    border-top:
    1px solid rgba(255,255,255,.08);
}

@keyframes fadeUp{

    from{
        opacity:0;
        transform:translateY(30px);
    }

    to{
        opacity:1;
        transform:translateY(0);
    }
}

@media(max-width:768px){

    header{
        flex-direction:column;
        gap:20px;
    }

    nav{
        display:flex;
        flex-wrap:wrap;
        justify-content:center;
    }

    .hero h1{
        font-size:2.8rem;
    }

    .newsletter button{
        margin-top:10px;
        margin-left:0;
    }
}
